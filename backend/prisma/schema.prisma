generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  FREELANCER
  BOTH
}

enum ProjectStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  CONFIRMED
  UNDER_REVIEW
  WAITING_PAYMENT
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum NotificationType {
  INFO
  PROJECT
  PAYMENT
  MESSAGE
}

enum ProjectSubmissionStatus {
  PENDING
  APPROVED
  REVISION_REQUESTED
}

model User {
  id             String               @id @default(cuid())
  fullName       String
  email          String               @unique
  passwordHash   String?
  googleId       String?              @unique
  avatarUrl      String?
  role           UserRole?
  phone          String?
  city           String?
  bio            String?
  specialty      String?
  startingPrice  Int?
  isAvailable    Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  clientProjects Project[]            @relation("ClientProjects")
  freelancerJobs Project[]            @relation("FreelancerProjects")
  applications   ProjectApplication[]
  portfolioItems PortfolioItem[]
  sentMessages   Message[]            @relation("SentMessages")
  receivedMessages Message[]          @relation("ReceivedMessages")
  notifications  Notification[]
}

model Project {
  id            String               @id @default(cuid())
  title         String
  description   String
  category      String
  serviceType   String?
  province      String?
  city          String?
  district      String?
  village       String?
  postalCode    String?
  address       String?
  addressDetail String?
  latitude      Float?
  longitude     Float?
  locationSource String?
  budget        Int?
  eventDate     DateTime?
  deadline      DateTime?
  status        ProjectStatus        @default(OPEN)
  progress      Int                  @default(0)
  clientId      String
  freelancerId  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  client        User                 @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  freelancer    User?                @relation("FreelancerProjects", fields: [freelancerId], references: [id], onDelete: SetNull)
  applications  ProjectApplication[]
  files         ProjectFile[]
  invoices      Invoice[]
  histories     ProjectHistory[]
  submissions   ProjectSubmission[]
  reviews       FreelancerReview[]
}

model ProjectApplication {
  id           String            @id @default(cuid())
  projectId    String
  freelancerId String
  message      String?
  serviceType   String?
  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancer   User              @relation(fields: [freelancerId], references: [id], onDelete: Cascade)

  @@unique([projectId, freelancerId])
}

model PortfolioItem {
  id          String   @id @default(cuid())
  freelancerId String
  title       String
  category    String?
  serviceType String?
  description String?
  fileUrl     String?
  fileName    String?
  fileType    String?
  fileSize    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  freelancer  User     @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
}

model ProjectFile {
  id          String   @id @default(cuid())
  projectId   String
  fileName    String
  fileKey     String
  contentType String?
  size        Int?
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model FreelancerReview {
  id           String   @id @default(cuid())
  projectId    String   @unique
  clientId     String
  freelancerId String
  rating       Int
  comment      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([freelancerId, createdAt])
}

model ProjectSubmission {
  id            String                  @id @default(cuid())
  projectId     String
  freelancerId  String
  comment       String
  fileUrl       String?
  fileName      String?
  fileType      String?
  fileSize      Int?
  status        ProjectSubmissionStatus @default(PENDING)
  reviewComment String?
  reviewedAt    DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  project       Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Invoice {
  id        String   @id @default(cuid())
  projectId String
  number    String   @unique
  amount    Int
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  body       String
  imageUrl   String?
  imageName  String?
  imageMime  String?
  imageSize  Int?
  readAt     DateTime?
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model ProjectHistory {
  id        String   @id @default(cuid())
  projectId String
  actorId   String?
  title     String
  body      String?
  eventType String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(INFO)
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}
