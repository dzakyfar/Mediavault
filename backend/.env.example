DATABASE_URL="postgresql://mediavault:mediavaultpass@localhost:5433/mediavault_dev"
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET="your-mediavault-bucket"
AWS_ACCESS_KEY_ID="your-iam-access-key"
AWS_SECRET_ACCESS_KEY="your-iam-secret-key"
# Optional for S3-compatible storage/localstack:
# AWS_S3_ENDPOINT="http://localhost:4566"
# AWS_S3_FORCE_PATH_STYLE="true"
PORT=5000
NODE_ENV=production
PUBLIC_APP_URL="https://domain-frontend-kamu.com"

# Telegram Bot Notifications
# Buat bot via @BotFather, simpan token dan username bot tanpa @.
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_USERNAME="your_bot_username"

# LOCAL / DEPLOY HTTP (tanpa HTTPS/domain):
# Pakai polling. Tidak perlu setWebhook, backend akan getUpdates otomatis.
TELEGRAM_BOT_MODE="polling"
TELEGRAM_POLLING_INTERVAL_MS=5000

# DEPLOY HTTPS / DOMAIN PRODUCTION:
# Ganti TELEGRAM_BOT_MODE="webhook", lalu jalankan:
# https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://api-domain.com/api/telegram/webhook&secret_token=<SECRET>
TELEGRAM_WEBHOOK_SECRET="change-this-telegram-webhook-secret"

# KlikQRIS Payment Gateway
# Dapatkan API Key dan Merchant ID dari dashboard merchant KlikQRIS
KLIKQRIS_API_KEY="your-klikqris-api-key"
KLIKQRIS_MERCHANT_ID="your-klikqris-merchant-id"
# URL API KlikQRIS (default production: https://klikqris.com/api/qrisv2)
KLIKQRIS_BASE_URL="https://klikqris.com/api/qrisv2"
# Set ke "sandbox" untuk testing, kosongkan atau "production" untuk live
KLIKQRIS_MODE="production"
# Minimum amount untuk gateway (default: 1 production, 500 sandbox)
# KLIKQRIS_MIN_AMOUNT=1
