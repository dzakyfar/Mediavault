NODE_ENV=production
PORT=5000
DATABASE_URL="postgresql://mediavault_app:CHANGE_ME@localhost:5432/mediavault?schema=public"
JWT_SECRET="CHANGE_ME_MIN_32_CHARS"
JWT_EXPIRES_IN="7d"
CORS_ORIGINS="http://localhost:5173,http://mediavault-frontend-xxx.s3-website-ap-southeast-1.amazonaws.com,https://your-cloudfront-domain.cloudfront.net"
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET_USERFILES="mediavault-userfiles-xxx"
PRESIGNED_URL_EXPIRES_SECONDS=300
MAX_UPLOAD_BYTES=52428800
